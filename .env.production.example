# ─── Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://pbevoxnglfbtxwgbbncp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── NextAuth ────────────────────────────────────────────────────────
NEXTAUTH_URL=https://app.ainewworld.in
NEXTAUTH_SECRET=your-nextauth-secret
AUTH_TRUST_HOST=true

# ─── WhatsApp Cloud API ──────────────────────────────────────────────
WA_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WA_ACCESS_TOKEN=your-whatsapp-access-token
WA_VERIFY_TOKEN=your-webhook-verify-token
WA_API_URL=https://graph.facebook.com/v21.0/your-phone-number-id

# ─── Razorpay ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ─── SMTP (Email) ────────────────────────────────────────────────────
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ─── Internal API Security ───────────────────────────────────────────
INTERNAL_API_KEY=your-internal-api-key

# ─── OpenAI (for WhatsApp AI Agent) ──────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Database (for scripts only) ─────────────────────────────────────
DB_PASSWORD=your-supabase-db-password
DB_HOST=db.pbevoxnglfbtxwgbbncp.supabase.co

# ─── Defaults ────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=T001
ADMIN_ALERT_PHONE=your-admin-phone
